<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.megacoffee.modules.system.SystemRepository">
  <select id="selectMenuList" resultType="com.megacoffee.modules.system.menu.MenuVO">
    SELECT
      *
    FROM
      menu
    WHERE
      use_yn = 'Y'
    ORDER BY
      sort_order ASC
  </select>
</mapper>
